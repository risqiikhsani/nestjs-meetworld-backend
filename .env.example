PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meetworld

JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=1d

REDIS_URL=redis://localhost:6379

# Rate limiting (global, per IP). Per-route auth limits are hardcoded
# in src/auth/auth.controller.ts because they are security-critical.
#
# THROTTLE_ENABLED turns the whole feature on/off. Defaults to false.
# When false, ALL throttling is skipped — including the hardcoded
# 5/min login and 3/hr register limits. Set to true in any environment
# that should be rate-limited (typically production). Requires a restart
# to toggle.
THROTTLE_ENABLED=false
THROTTLE_TTL=60000      # window in ms
THROTTLE_LIMIT=60       # max requests per window per IP

# Storage backend selection
STORAGE_PROVIDER=gcs                # "s3" (default) or "gcs"

# S3 config (required when STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
AWS_S3_BUCKET=meetworld-uploads
# AWS_S3_ENDPOINT=                  # optional: set for MinIO/LocalStack

# GCS config (required when STORAGE_PROVIDER=gcs)
# GCS_BUCKET=meetworld-uploads
