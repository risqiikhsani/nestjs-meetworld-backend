  },
  "info": {
    "title": "MeetWorld API",
    "description": "REST API for the MeetWorld backend. Every route under `/api` (except `/api/auth/register`, `/api/auth/login`, `/api/health`) requires a JWT bearer token. Get one from `POST /api/auth/login` and paste it into the Authorize dialog as `Bearer <token>`.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "auth",
      "description": "Registration and login (public)."
    },
    {
      "name": "users",
      "description": "User CRUD."
    },
    {
      "name": "posts",
      "description": "Posts scoped under a user (`:userId/posts`)."
    },
    {
      "name": "comments",
      "description": "Comments scoped under a post (`/posts/:postId/comments`)."
    },
    {
      "name": "profiles",
      "description": "Profile scoped under a user (`:userId/profile`)."
    },
    {
      "name": "uploads",
      "description": "Multipart file uploads to S3."
    },
    {
      "name": "health",
      "description": "Liveness/readiness probe (public)."
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "JWT issued by `POST /api/auth/login`."
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "alice@example.com",
            "format": "email",
            "maxLength": 120
          },
          "password": {
            "type": "string",
            "example": "correct-horse-battery-staple",
            "description": "Plaintext password; bcrypt-hashed server-side at cost 12.",
            "minLength": 8
          },
          "name": {
            "type": "string",
            "example": "Alice",
            "minLength": 1,
            "maxLength": 80
          }
        },
        "required": [
          "email",
          "password",
          "name"
        ]
      },
      "SafeUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "example": "alice@example.com"
          },
          "name": {
            "type": "string",
            "example": "Alice"
          }
        },
        "required": [
          "id",
          "email",
          "name"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Signed JWT. Paste into the Authorize dialog as `Bearer <token>`.",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "$ref": "#/components/schemas/SafeUserDto"
          }
        },
        "required": [
          "access_token",
          "user"
        ]
      },
      "ErrorResponseDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 400
          },
          "timestamp": {
            "type": "string",
            "example": "2026-06-18T12:34:56.789Z",
            "description": "ISO-8601 timestamp the error was produced"
          },
          "path": {
            "type": "string",
            "example": "/api/users/not-a-uuid"
          },
          "message": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ],
            "example": "User with id \"not-a-uuid\" was not found"
          }
        },
        "required": [
          "statusCode",
          "timestamp",
          "path",
          "message"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "alice@example.com",
            "format": "email"
          },
          "password": {
            "type": "string",
            "example": "correct-horse-battery-staple"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "text": {
            "type": "string",
            "example": "My comment to this post",
            "maxLength": 200
          },
          "authorId": {
            "type": "string",
            "format": "uuid"
          },
          "postId": {
            "type": "string",
            "format": "uuid"
          },
          "post": {
            "$ref": "#/components/schemas/Post"
          },
          "author": {
            "$ref": "#/components/schemas/User"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "text",
          "authorId",
          "postId",
          "post",
          "author",
          "createdAt",
          "updatedAt"
        ]
      },
      "Post": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "images": {
            "nullable": true,
            "description": "S3 URLs attached to this post (populated by the upload flow).",
            "example": [
              "https://meetworld-uploads.s3.us-east-1.amazonaws.com/2026-06-18/abc.jpg"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "title": {
            "type": "string",
            "example": "Hello, world",
            "maxLength": 200
          },
          "body": {
            "type": "string",
            "example": "First post on MeetWorld."
          },
          "authorId": {
            "type": "string",
            "format": "uuid"
          },
          "author": {
            "$ref": "#/components/schemas/User"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "comments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Comment"
            }
          }
        },
        "required": [
          "id",
          "images",
          "title",
          "body",
          "authorId",
          "author",
          "createdAt",
          "updatedAt",
          "comments"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "example": "alice@example.com",
            "maxLength": 120
          },
          "name": {
            "type": "string",
            "example": "Alice",
            "maxLength": 80
          },
          "passwordHash": {
            "type": "object",
            "description": "bcrypt hash. Documented here for completeness; stripped from JSON responses by the global `ClassSerializerInterceptor` (@Exclude).",
            "nullable": true,
            "minLength": 60,
            "maxLength": 60
          },
          "profile": {
            "$ref": "#/components/schemas/Profile"
          },
          "posts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Post"
            }
          },
          "comments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Comment"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "passwordHash",
          "posts",
          "comments",
          "createdAt",
          "updatedAt"
        ]
      },
      "Profile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          },
          "bio": {
            "type": "object",
            "nullable": true,
            "maxLength": 1000
          },
          "avatarUrl": {
            "type": "object",
            "nullable": true,
            "format": "uri",
            "maxLength": 500
          },
          "location": {
            "type": "object",
            "nullable": true,
            "maxLength": 100
          },
          "dateOfBirth": {
            "type": "object",
            "nullable": true,
            "format": "date",
            "example": "1995-04-12",
            "description": "ISO-8601 calendar date (YYYY-MM-DD)."
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "userId",
          "user",
          "bio",
          "avatarUrl",
          "location",
          "dateOfBirth",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Unique email address (used as the login identifier).",
            "example": "alice@example.com",
            "format": "email",
            "maxLength": 120
          },
          "name": {
            "type": "string",
            "example": "Alice",
            "minLength": 1,
            "maxLength": 80
          },
          "passwordHash": {
            "type": "string",
            "description": "bcrypt hash. Server-managed — direct callers should not set this. New users are created via `POST /api/auth/register`.",
            "minLength": 60,
            "maxLength": 60
          }
        }
      },
      "HealthDependencyDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ]
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "HealthCheckDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded"
            ]
          },
          "uptime": {
            "type": "number",
            "description": "Process uptime in seconds.",
            "example": 42
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "database": {
            "$ref": "#/components/schemas/HealthDependencyDto"
          },
          "redis": {
            "$ref": "#/components/schemas/HealthDependencyDto"
          }
        },
        "required": [
          "status",
          "uptime",
          "timestamp",
          "database",
          "redis"
        ]
      },
      "FeedResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Post"
            }
          },
          "nextCursor": {
            "type": "object",
            "description": "Opaque token to pass as `cursor` to fetch the next page. `null` when there are no more posts.",
            "nullable": true,
            "example": "eyJ0IjoiMjAyNi0wNi0xOFQxMjozNDoxNloifQ"
          }
        },
        "required": [
          "items",
          "nextCursor"
        ]
      },
      "CreatePostDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Hello, world",
            "minLength": 1,
            "maxLength": 200
          },
          "body": {
            "type": "string",
            "example": "First post on MeetWorld.",
            "minLength": 1,
            "maxLength": 10000
          }
        },
        "required": [
          "title",
          "body"
        ]
      },
      "UpdatePostDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Hello, world",
            "minLength": 1,
            "maxLength": 200
          },
          "body": {
            "type": "string",
            "example": "First post on MeetWorld.",
            "minLength": 1,
            "maxLength": 10000
          }
        }
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "bio": {
            "type": "string",
            "maxLength": 1000
          },
          "avatarUrl": {
            "type": "string",
            "format": "uri",
            "maxLength": 500
          },
          "location": {
            "type": "string",
            "maxLength": 100
          },
          "dateOfBirth": {
            "type": "string",
            "description": "ISO-8601 date string (YYYY-MM-DD).",
            "example": "1995-04-12",
            "format": "date"
          }
        }
      },
      "CreateCommentDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "example": "My comment on this post",
            "minLength": 1,
            "maxLength": 200
          }
        },
        "required": [
          "text"
        ]
      },
      "UpdateCommentDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "example": "My comment on this post",
            "minLength": 1,
            "maxLength": 200
          }
        }
      }
    }
  }
}